generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model alerts {
  id           BigInt    @id @default(autoincrement())
  triggered_at DateTime? @default(now()) @db.Timestamptz(6)
  pollutant    String?
  value        Float?
  threshold    Float?
  severity     String?
  notified     Boolean?  @default(false)
}

model aqi_records {
  id          BigInt    @id @default(autoincrement())
  timestamp   DateTime? @default(now()) @db.Timestamptz(6)
  pm25_aqi    Int?
  pm10_aqi    Int?
  overall_aqi Int?
  category    String?
}

model predictions {
  id             BigInt    @id @default(autoincrement())
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  forecast_time  DateTime  @db.Timestamptz(6)
  pm25_predicted Float?
  pm25_lower     Float?
  pm25_upper     Float?
  pm10_predicted Float?
  model_used     String?
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model sensor_data {
  time        DateTime @db.Timestamptz(6)
  device_id   String
  pm25        Float?
  pm10        Float?
  temperature Float?
  humidity    Float?
  id          BigInt   @default(autoincrement())

  @@id([time, id])
  @@index([time(sort: Desc)])
  @@ignore
}
